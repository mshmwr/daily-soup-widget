  "quotes": {
    "0001": {
      "text": "千里之行，始於足下。",
      "author": "老子",
      "source": "《道德經·第六十四章》",
      "sourceUrl": "https://ctext.org/dao-de-jing/zh",
      "attribution": "verified",
      "dimension": "action",
      "style": "classical"
    },
    "0003": {
      "text": "知是行之始，行是知之成。",
      "author": "王陽明",
      "source": "《傳習錄·上》",
      "sourceUrl": "https://ctext.org/wiki.pl?if=gb&res=86081",
      "attribution": "verified",
      "dimension": "action",
      "style": "classical"
    },
    "0004": {
      "text": "人生須知負責任的苦處，才能知道盡責任的樂趣。",
      "author": "梁啟超",
      "source": "《最苦與最樂》(1922)",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "action",
      "style": "vernacular"
    },
    "0005": {
      "text": "人，只要勤勞動，腳是不會老的。",
      "author": "老舍",
      "source": "老舍語錄",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "action",
      "style": "vernacular"
    },
    "0006": {
      "text": "吾心信其可行，則移山填海之難，終有成功之日。",
      "author": "孫中山",
      "source": "《孫文學說》(1919)",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "action",
      "style": "vernacular"
    },
    "0007": {
      "text": "三人行，必有我師焉；擇其善者而從之，其不善者而改之。",
      "author": "孔子",
      "source": "《論語·述而》",
      "sourceUrl": "https://ctext.org/analects/shu-er/zh",
      "attribution": "verified",
      "dimension": "learning",
      "style": "classical"
    },
    "0008": {
      "text": "學而時習之，不亦說乎？",
      "author": "孔子",
      "source": "《論語·學而》",
      "sourceUrl": "https://ctext.org/analects/xue-er/zh",
      "attribution": "verified",
      "dimension": "learning",
      "style": "classical"
    },
    "0009": {
      "text": "滴水穿石，非一日之功。",
      "author": "民間諺語",
      "source": "古諺；意源自宋·羅大經《鶴林玉露》「繩鋸木斷，水滴石穿」",
      "sourceUrl": "",
      "attribution": "proverb",
      "dimension": "learning",
      "style": "vernacular"
    },
    "0011": {
      "text": "問渠那得清如許？為有源頭活水來。",
      "author": "朱熹",
      "source": "宋·朱熹《觀書有感》",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "learning",
      "style": "poetry"
    },
    "0012": {
      "text": "古之立大事者，不惟有超世之才，亦必有堅忍不拔之志。",
      "author": "蘇軾",
      "source": "宋·蘇軾《晁錯論》",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "perseverance",
      "style": "classical"
    },
    "0013": {
      "text": "雖千萬人，吾往矣。",
      "author": "孟子",
      "source": "《孟子·公孫丑上》",
      "sourceUrl": "https://ctext.org/mengzi/gong-sun-chou-i/zh",
      "attribution": "verified",
      "dimension": "perseverance",
      "style": "classical"
    },
    "0014": {
      "text": "莫等閒，白了少年頭，空悲切。",
      "author": "岳飛",
      "source": "宋·岳飛《滿江紅》",
      "sourceUrl": "",
      "attribution": "popular-attribution",
      "dimension": "perseverance",
      "style": "poetry"
    },
    "0016": {
      "text": "怕什麼真理無窮，進一寸有一寸的歡喜。",
      "author": "胡適",
      "source": "胡適語錄",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "perseverance",
      "style": "vernacular"
    },
    "0017": {
      "text": "天下無難事，只怕有心人。",
      "author": "民間諺語",
      "source": "《西遊記》第二回；早為民間流傳俗語",
      "sourceUrl": "",
      "attribution": "proverb",
      "dimension": "mindset",
      "style": "vernacular"
    },
    "0021": {
      "text": "非淡泊無以明志，非寧靜無以致遠。",
      "author": "諸葛亮",
      "source": "三國·諸葛亮《誡子書》",
      "sourceUrl": "https://ctext.org/wiki.pl?if=en&res=78566",
      "attribution": "verified",
      "dimension": "mindset",
      "style": "classical"
    },
    "0022": {
      "text": "三十而立，四十而不惑，五十而知天命。",
      "author": "孔子",
      "source": "《論語·為政》",
      "sourceUrl": "https://ctext.org/analects/wei-zheng/zh",
      "attribution": "verified",
      "dimension": "mindset",
      "style": "classical"
    },
    "0025": {
      "text": "鵬之徙於南冥也，水擊三千里，摶扶搖而上者九萬里。",
      "author": "莊子",
      "source": "《莊子·逍遙遊》",
      "sourceUrl": "https://ctext.org/zhuangzi/enjoyment-in-untroubled-ease/zh",
      "attribution": "verified",
      "dimension": "transformation",
      "style": "classical"
    },
    "0026": {
      "text": "燕子去了，有再來的時候；楊柳枯了，有再青的時候；桃花謝了，有再開的時候。",
      "author": "朱自清",
      "source": "朱自清《匆匆》",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "transformation",
      "style": "vernacular"
    },
    "0027": {
      "text": "天將降大任於是人也，必先苦其心志，勞其筋骨，餓其體膚。",
      "author": "孟子",
      "source": "《孟子·告子下》",
      "sourceUrl": "https://ctext.org/mengzi/gaozi-ii/zh",
      "attribution": "verified",
      "dimension": "purpose",
      "style": "classical"
    },
    "0030": {
      "text": "老驥伏櫪，志在千里；烈士暮年，壯心不已。",
      "author": "曹操",
      "source": "漢·曹操《步出夏門行·龜雖壽》",
      "sourceUrl": "",
      "attribution": "verified",
      "dimension": "purpose",
      "style": "poetry"
    }
  }
}