  "quotes": {
    "0002": {
      "text": "The beginning is the most important part of the work.",
      "author": "Plato",
      "source": "Republic, Book II",
      "sourceUrl": "https://en.wikisource.org/wiki/The_Republic_of_Plato",
      "attribution": "verified",
      "dimension": "action",
      "style": "classical"
    },
    "0010": {
      "text": "We are what we repeatedly do. Excellence, then, is not an act, but a habit.",
      "author": "Aristotle (paraphrase by Will Durant)",
      "source": "Nicomachean Ethics, Book II (paraphrase); originated in Durant's The Story of Philosophy",
      "sourceUrl": "https://en.wikisource.org/wiki/Nicomachean_Ethics",
      "attribution": "popular-attribution",
      "dimension": "learning",
      "style": "classical"
    },
    "0015": {
      "text": "That which does not kill us makes us stronger.",
      "author": "Friedrich Nietzsche",
      "source": "Twilight of the Idols (1889)",
      "sourceUrl": "https://en.wikisource.org/wiki/Twilight_of_the_Idols",
      "attribution": "verified",
      "dimension": "perseverance",
      "style": "modern"
    },
    "0018": {
      "text": "You have power over your mind — not outside events. Realize this, and you will find strength.",
      "author": "Marcus Aurelius",
      "source": "Meditations, Book VIII",
      "sourceUrl": "https://en.wikisource.org/wiki/Meditations",
      "attribution": "verified",
      "dimension": "mindset",
      "style": "classical"
    },
    "0019": {
      "text": "The happiness of your life depends upon the quality of your thoughts.",
      "author": "Marcus Aurelius",
      "source": "Meditations",
      "sourceUrl": "https://en.wikisource.org/wiki/Meditations",
      "attribution": "verified",
      "dimension": "mindset",
      "style": "classical"
    },
    "0020": {
      "text": "It is not what happens to you, but how you react to it that matters.",
      "author": "Epictetus",
      "source": "Enchiridion",
      "sourceUrl": "https://en.wikisource.org/wiki/Enchiridion",
      "attribution": "verified",
      "dimension": "mindset",
      "style": "classical"
    },
    "0023": {
      "text": "When I let go of what I am, I become what I might be.",
      "author": "Lao Tzu (popular English rendering)",
      "source": "Tao Te Ching, popular English translation",
      "sourceUrl": "",
      "attribution": "popular-attribution",
      "dimension": "transformation",
      "style": "modern"
    },
    "0024": {
      "text": "I am not what happened to me, I am what I choose to become.",
      "author": "Carl Jung (popularly attributed)",
      "source": "Popularly attributed to Jung",
      "sourceUrl": "",
      "attribution": "popular-attribution",
      "dimension": "transformation",
      "style": "modern"
    },
    "0028": {
      "text": "He who has a why to live for can bear almost any how.",
      "author": "Friedrich Nietzsche",
      "source": "Twilight of the Idols (1889)",
      "sourceUrl": "https://en.wikisource.org/wiki/Twilight_of_the_Idols",
      "attribution": "verified",
      "dimension": "purpose",
      "style": "modern"
    },
    "0029": {
      "text": "The two most important days in your life are the day you are born and the day you find out why.",
      "author": "Mark Twain (popularly attributed)",
      "source": "Popularly attributed; Twain d. 1910, PD globally",
      "sourceUrl": "",
      "attribution": "popular-attribution",
      "dimension": "purpose",
      "style": "modern"
    }
